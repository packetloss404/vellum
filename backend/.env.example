ANTHROPIC_API_KEY=replace-me

VELLUM_DB_PATH=./vellum.db
VELLUM_MODEL=claude-opus-4-7
VELLUM_MODEL_ALT=claude-sonnet-4-6
VELLUM_SECTION_TOKEN_BUDGET=30000
VELLUM_LOOP_DETECTION_THRESHOLD=3

# Optional local API guard. Empty token keeps localhost dev unchanged.
VELLUM_API_TOKEN=
VELLUM_API_AUTH_REQUIRED=false

# Hard agent run limits.
VELLUM_AGENT_MAX_TURNS=200
VELLUM_SUB_AGENT_MAX_TURNS=60
VELLUM_AGENT_MAX_CONCURRENT_RUNS=2
